<div class="table-wrapper">
  <div class="table-header">
    <h2>🗳️ Submitted Credentials</h2>
    <span class="count"
      ><%= results.length %> record<%= results.length !== 1 ? 's' : '' %></span
    >
  </div>

  <% if (results.length === 0) { %>
  <div class="empty-state">
    <span>📭</span>
    <p>No records found.</p>
  </div>
  <% } else { %>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Email</th>
          <th>Code</th>
        </tr>
      </thead>
      <tbody>
        <% results.forEach((user, index) => { %>
        <tr class="fade-row" style="animation-delay: <%= index * 40 %>ms">
          <td class="row-num"><%= index + 1 %></td>
          <td><%= user.email %></td>
          <td><span class="code-badge"><%= user.code %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
